# =============================================
# ENVIRONMENT VARIABLES FOR DRONE SCOPE
# =============================================

# Copy this file to .env.local and fill in the values

# -----------------------------------------
# CONTACT FORM
# -----------------------------------------

# Option 1: Using Resend (recommended for production)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Option 2: Using Formspree (simpler, no API key needed in code)
# Just update the endpoint directly in the Contact component:
# https://formspree.io/f/YOUR_FORM_ID

# -----------------------------------------
# OPTIONAL: Analytics / Other
# -----------------------------------------
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
